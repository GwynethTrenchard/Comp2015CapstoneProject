<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1980" d:DesignHeight="1080"
             x:Class="Frontend.ui.JournalView">
 <ScrollViewer>
        <Grid RowDefinitions="*,*,*"
              ColumnDefinitions="*,*,*"
              RowSpacing="20"
              Margin="20">

            <!-- ===========================
                 TOP BAR
                 =========================== -->
            <Grid Grid.ColumnSpan="3"
                  ColumnDefinitions="Auto,*,Auto">

               

                <!-- Title -->
                <TextBlock Grid.Column="1"
                           Grid.Row="0"
                           Text="Journal"
                           FontSize="64"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                           
                            <!-- Add Note Button -->
                
                           
                           
                           
                           

                <!-- Return Button -->
                <Button Grid.Column="2"
                        Grid.Row="0"
                        Content="Return"
                        Click="OnReturnClicked"
                        Width="180"
                        Height="60"
                        FontSize="24"
                        FontWeight="Bold"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        HorizontalAlignment="Right"/>
            

     </Grid>
           

            <Grid>
                   <UniformGrid Columns="1"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Top"
                             Margin="0,40,0,0">
                       <Expander 
                          Grid.Column="1"
                          Grid.Row="1"
                    
                          Header="Create a New Note"
                          
                          FontSize="18"
                          FontWeight="Bold"
                          HorizontalContentAlignment="Center"
                          VerticalContentAlignment="Center"
                          IsExpanded="False">


                          <StackPanel Spacing="10">

                            <!-- Description -->
                            <StackPanel>
                                <TextBlock Text="Private Note:"/>
                                <TextBox AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Height="120"
                                         Watermark="Enter Private Note Here"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Public Note:"/>
                                <TextBox AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Height="120"
                                         Watermark="Enter Public Note Here"/>
                            </StackPanel>

                            <Button Content="Save Note"
                                Click="OnSaveNoteClicked"
                                Height="50"
                                FontSize="18"
                                FontWeight="Bold"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"/>

                        </StackPanel>
                </Expander>

                    </UniformGrid>
                    
                
              </Grid>

            <!-- ===========================
                 NOTE GRID (UNIFORMGRID)
                 =========================== -->
            <ScrollViewer Grid.Row="2"
                          Grid.ColumnSpan="3"
                          VerticalScrollBarVisibility="Auto">

                <UniformGrid Columns="2"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Top"
                             Margin="0,40,0,0">

                    <!-- Larger Note Buttons with more spacing -->
                    <Button Content="Note 1"
                            Click="OnNoteClicked"
                            Width="400"
                            Height="115"
                            FontSize="36"
                            FontWeight="Bold"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Margin="60"/>

                    <Button Content="Note 2"
                            Click="OnNoteClicked"
                            Width="400"
                            Height="115"
                            FontSize="36"
                            FontWeight="Bold"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Margin="60"/>


                </UniformGrid>

            </ScrollViewer>

             

        </Grid>
    </ScrollViewer>




</UserControl>
 